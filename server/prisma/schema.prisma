generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum UserRole {
  ADMIN
  MANAGER
  STAFF
  USER
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum FulfillmentType {
  PICKUP
  DELIVERY
}

enum DeliveryStatus {
  NOT_APPLICABLE
  PENDING
  LOADING
  IN_TRANSIT
  DELIVERED
}

enum InventoryTransactionType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
}

// --- MODELS ---

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?   @db.Text
  products    Product[]
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("categories")
}

model Product {
  id            String      @id @default(uuid())
  name          String      @map("product_name")
  specification String?
  sku           String      @unique
  price         Decimal     @db.Decimal(12, 2)
  costPrice     Decimal     @db.Decimal(12, 2) @map("cost_price")
  quantity      Int         @default(0)
  unit          String      @default("pcs")
  reorderLevel  Int         @default(10) @map("reorder_level")
  categoryId    String      @map("category_id")
  category      Category    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems    OrderItem[]
  transactions  InventoryTransaction[] // 2) Link product to stock logs
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("inventory")
}

model InventoryTransaction {
  id          String                   @id @default(uuid())
  productId   String                   @map("product_id")
  product     Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type        InventoryTransactionType
  quantity    Int                      // Signed only for ADJUSTMENT in our service rule
  reason      String                   @db.Text
  previousQty Int                      @map("previous_qty")
  newQty      Int                      @map("new_qty")
  createdBy   String?                  @map("created_by")
  createdAt   DateTime                 @default(now()) @map("created_at")

  @@index([productId, createdAt])
  @@map("inventory_transactions")
}

model User {
  id            String    @id @default(uuid())
  username      String    @unique
  email         String    @unique
  contactNumber String?   @map("contact_number")
  address       String?   @db.Text
  passwordHash  String    @map("password_hash")
  role          UserRole  @default(USER)
  isActive      Boolean   @default(true) @map("is_active")
  orders        Order[]
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("users")
}

model Order {
  id              String          @id @default(uuid())
  userId          String          @map("user_id")
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalAmount     Decimal         @default(0) @map("total_amount") @db.Decimal(12, 2)
  status          OrderStatus     @default(PENDING)
  
  // Logistics Fields
  fulfillmentType FulfillmentType @default(PICKUP) @map("fulfillment_type")
  deliveryStatus  DeliveryStatus  @default(NOT_APPLICABLE) @map("delivery_status")
  deliveryAddress String?         @db.Text @map("delivery_address")
  scheduledDate   DateTime?       @map("scheduled_date")
  
  items           OrderItem[]
  createdAt       DateTime        @default(now()) @map("created_at")

  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String   @map("product_id")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity   Int
  unitPrice  Decimal  @map("unit_price") @db.Decimal(12, 2)
  // Subtotal is usually handled in the logic layer, 
  // but we store it for historical accuracy.
  subtotal   Decimal  @db.Decimal(12, 2)

  @@map("order_items")
}